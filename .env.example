# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Your Supabase Project URL (e.g., https://xyz.supabase.co)
VITE_SUPABASE_URL=https://zumysyuenxrylauzvokl.supabase.co

# SUPABASE_ANON_KEY: Your Supabase Public Anonymous Key
VITE_SUPABASE_ANON_KEY=

# SUPABASE_SERVICE_ROLE_KEY: Your Supabase Service Role Key (Keep this secret!)
SUPABASE_SERVICE_ROLE_KEY=

# DATABASE_URL: PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.zumysyuenxrylauzvokl.supabase.co:5432/postgres

# SUPABASE_ACCESS_TOKEN: Your Supabase Management Access Token
SUPABASE_ACCESS_TOKEN=
